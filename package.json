{
  "name": "re-class-mcp",
  "version": "0.3.0",
  "description": "FastMCP server and hot-swappable ReClass.NET bridge plugin.",
  "type": "module",
  "bin": {
    "re-class-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "plugin",
    "plugins",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "dev": "tsx server/src/cli.ts stdio",
    "doctor": "node ./dist/cli.js doctor",
    "lint": "tsc --noEmit -p tsconfig.json",
    "smoke": "node ./dist/cli.js smoke --auto-launch --platform x64",
    "review": "npm run lint && npm run build:server",
    "plugin:build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-plugin.ps1 -Configuration Release -Platform x64",
    "plugin:build:all": "npm run plugin:build:x64 && npm run plugin:build:x86",
    "plugin:build:x64": "powershell -ExecutionPolicy Bypass -File ./scripts/build-plugin.ps1 -Configuration Release -Platform x64",
    "plugin:build:x86": "powershell -ExecutionPolicy Bypass -File ./scripts/build-plugin.ps1 -Configuration Release -Platform x86",
    "plugin:install:x64": "powershell -ExecutionPolicy Bypass -File ./scripts/build-plugin.ps1 -Configuration Release -Platform x64 -StartReClass:$true",
    "plugin:install:x86": "powershell -ExecutionPolicy Bypass -File ./scripts/build-plugin.ps1 -Configuration Release -Platform x86 -StartReClass:$true",
    "codex:install:local": "node ./dist/cli.js install-codex --mode local --auto-launch --platform x64",
    "codex:install:github": "node ./dist/cli.js install-codex --mode github --github-repo tonytranrp/re-class-mcp --auto-launch --platform x64"
  },
  "keywords": [
    "mcp",
    "reclass",
    "fastmcp",
    "reverse-engineering",
    "codex"
  ],
  "author": "tonytranrp",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastmcp": "3.34.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  }
}
